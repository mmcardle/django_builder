{
  "name": "djangobuilder.io",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "django-builder": "bin/django-builder"
  },
  "scripts": {
    "dev": "vite --port 8080",
    "build": "vite build",
    "serve": "vite preview",
    "lint": "eslint ./src/ ./tests",
    "lint:fix": "yarn run lint --fix",
    "test:unit": "vitest --run",
    "pree2e": "yarn bic",
    "preci": "yarn bic"
  },
  "dependencies": {
    "@djangobuilder/core": "1.0.0",
    "@highlightjs/vue-plugin": "^2.1.0",
    "@mdi/js": "^7.4.47",
    "esm": "^3.2.25",
    "firebase": "^11.1.0",
    "firebase-tools": "^15.22.3",
    "highlight.js": "^11.2.0",
    "pinia": "^3.0.4",
    "tar-js": "^0.3.0",
    "vue": "^3.5.39",
    "vue-gtag": "^3.7.1",
    "vue-router": "^4.6.4",
    "vuetify": "^3.12.8"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.53.0",
    "@typescript-eslint/parser": "^5.53.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/ui": "^3.2.6",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.4.8",
    "build-if-changed": "^1.5.5",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.32.0",
    "eslint-plugin-vuetify": "^2.7.2",
    "jsdom": "^20.0.1",
    "sass": "^1.54.5",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^6.4.3",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^3.2.6"
  },
  "bic": [
    "src"
  ],
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ]
}
