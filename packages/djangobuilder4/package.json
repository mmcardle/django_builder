{
  "name": "djangobuilder4",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 8080",
    "build": "run-p type-check build-only",
    "build:development": "run-s type-check build-only:development",
    "build:staging": "run-s type-check build-only:staging",
    "preview": "vite preview --port 4173",
    "build-only": "vite build --base=/db4/",
    "build-only:staging": "vite build --mode=staging --base=/db4/",
    "build-only:development": "vite build --mode=development --base=/db4/",
    "type-check": "vue-tsc --noEmit -p tsconfig.json --composite false",
    "lint": "eslint ./src/",
    "lint:fix": "eslint ./src/ --fix"
  },
  "dependencies": {
    "@djangobuilder/core": "1.0.0",
    "@highlightjs/vue-plugin": "^2.1.0",
    "firebase": "^11.10.0",
    "highlight.js": "^11.11.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.1.3",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "npm-run-all2": "^7.0.2",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "start-server-and-test": "^2.0.12",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.4.20",
    "vue-tsc": "^2.2.10"
  }
}
